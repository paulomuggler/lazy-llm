#!/usr/bin/env bash
# llm-append - Appends text to prompt pane without clearing or submitting
# Usage: llm-append [--raw] "text to append"
#        echo "text" | llm-append [--raw]
#   --raw: insert inline without extra newlines
# Content can be passed as an argument or piped via stdin.

set -euo pipefail

# Source shared library for pane resolution
source "$(dirname "$0")/lazy-llm-lib.sh"

# Parse flags
RAW_MODE=false
if [[ "${1:-}" == "--raw" ]]; then
  RAW_MODE=true
  shift
fi

# Get content from argument or stdin
if [[ -n "${1:-}" ]]; then
  CONTENT="$1"
elif [[ ! -t 0 ]]; then
  CONTENT=$(cat)
else
  echo "Error: No content provided (pass as argument or pipe via stdin)" >&2
  exit 1
fi

# Resolve prompt pane target
lazy_llm_resolve_pane || true
if [[ -n "${_CURRENT_PANE:-}" ]]; then
  lazy_llm_resolve_session_window || true
fi
if [[ -n "${_SESSION:-}" ]]; then
  TARGET=$(lazy_llm_get_prompt_target)
else
  TARGET=":.2"
fi

# Validate prompt pane is still alive
if ! lazy_llm_validate_pane "$TARGET"; then
  echo "Error: Prompt pane $TARGET no longer exists" >&2
  exit 1
fi

# CRITICAL: Exit copy-mode if pane is scrolled up
tmux send-keys -t "$TARGET" -X cancel 2>/dev/null || true

# Ensure nvim is in normal mode, then position cursor at end of line
tmux send-keys -t "$TARGET" Escape
tmux send-keys -t "$TARGET" A

if [[ "$RAW_MODE" == "true" ]]; then
  # Raw mode: append inline at cursor position (no extra newlines)
  printf '%s' "$CONTENT" | tmux load-buffer -
  tmux paste-buffer -t "$TARGET"
else
  # Wrapped mode: add blank line spacing before and after content
  tmux send-keys -t "$TARGET" Enter Enter
  printf '%s\n' "$CONTENT" | tmux load-buffer -
  tmux paste-buffer -t "$TARGET"
fi
