#!/usr/bin/env bash
# llm-dashboard - Tabbed popup dashboard for lazy-llm
#
# Tabs:
#   1. Sessions  - list lazy-llm sessions with status glyphs + live ANSI preview
#   2. Worktrees - placeholder (real content lands in worktree-bridge-tab)
#
# Designed to be launched via `tmux display-popup -E`; binds to Prefix+S.
# All keybindings inside the popup are popup-scoped, single-letter, dense.
#
# Tab keys:           1 (Sessions), 2 (Worktrees)
# Sessions actions:   Enter (switch), n (new), K (kill), r (rename),
#                     R (refresh), ? (help), q/Esc (quit)
#
# Usage: llm-dashboard [--tab sessions|worktrees|panes] [--help]

set -euo pipefail

# Resolve lib path: try sibling first (post-install via stow), else dev location
_lib_sibling="$(dirname "$0")/lazy-llm-lib.sh"
if [[ -f "$_lib_sibling" ]]; then
  # shellcheck source=/dev/null
  source "$_lib_sibling"
else
  # shellcheck source=/dev/null
  source "$(dirname "$0")/../../../llm-send-bin/.local/bin/lazy-llm-lib.sh"
fi

# ──────────────────────────────────────────────────────────────────────────
# Glyph mapping (shared with llm-status; kept here too so the dashboard
# doesn't pull in another source file just for one tiny function).
# ──────────────────────────────────────────────────────────────────────────
glyph_for() {
  case "$1" in
    working) printf '●' ;;
    idle)    printf '○' ;;
    waiting) printf '◐' ;;
    *)       printf '?' ;;
  esac
}

# ──────────────────────────────────────────────────────────────────────────
# Sessions tab
# ──────────────────────────────────────────────────────────────────────────

# Render the sessions tab fzf list.
# Returns (echoes) one of:
#   "tab:worktrees" — switch to worktrees tab
#   "action:switch:<session>" — switch to selected session
#   "action:kill:<session>"   — kill selected session
#   "action:rename:<session>" — rename selected session
#   "action:new"              — launch new lazy-llm session
#   "action:refresh"          — re-render the tab
#   "action:help"             — show help overlay
#   "quit"                    — exit dashboard
render_sessions_tab() {
  local data
  data=$(lazy_llm_gather_sessions)

  local lines="" header
  if [[ -z "$data" ]]; then
    header="[Sessions] No lazy-llm sessions. n: new │ 2: worktrees │ 3: panes │ q/esc: close"
  else
    # Augment each row with a status glyph next to the tools column.
    while IFS=$'\t' read -r name dir tools wins attached; do
      # Resolve the active AI pane id for the first workspace window of this session.
      # First window index is base-index dependent (0 or 1) — query it.
      local first_win ai_pane_id status glyph
      first_win=$(tmux list-windows -t "$name" -F '#{window_index}' 2>/dev/null | head -1)
      ai_pane_id=$(tmux show-option -wv -t "$name:$first_win" @AI_PANE_ID 2>/dev/null) || ai_pane_id=""
      if [[ -n "$ai_pane_id" ]]; then
        local first_tool="${tools%% *}"
        status=$(lazy_llm_detect_pane_status "$ai_pane_id" "$first_tool")
        glyph=$(glyph_for "$status")
      else
        glyph="?"
      fi

      local short_dir="${dir/#$HOME/\~}"
      [[ ${#short_dir} -gt 40 ]] && short_dir="...${short_dir: -37}"

      local mark=""
      [[ -n "$attached" ]] && mark=" *"

      lines+=$(printf '%-28s  %-42s  %s %-14s %sw%s\n' \
        "$name" "$short_dir" "$glyph" "$tools" "$wins" "$mark")
      lines+=$'\n'
    done <<< "$data"
    lines="${lines%$'\n'}"
    header="[Sessions] enter: switch │ n: new │ K: kill │ r: rename │ R: refresh │ ?: help │ 2: worktrees │ 3: panes │ q/esc: close"
  fi

  # Preview command — takes the first column (session name) and shows the
  # tail of its active AI pane content, ANSI-rendered.
  local preview_cmd
  preview_cmd='set -- {1}; '
  preview_cmd+='session="$1"; '
  preview_cmd+='if [ -n "$session" ]; then '
  preview_cmd+='win=$(tmux list-windows -t "$session" -F "#{window_index}" 2>/dev/null | head -1); '
  preview_cmd+='pid=$(tmux show-option -wv -t "$session:$win" @AI_PANE_ID 2>/dev/null); '
  preview_cmd+='if [ -n "$pid" ]; then '
  preview_cmd+='tmux capture-pane -p -e -S -200 -t "$pid" 2>/dev/null || echo "(could not capture pane $pid)"; '
  preview_cmd+='else echo "(no AI pane registered for $session)"; fi; '
  preview_cmd+='fi'

  local selection key
  selection=$(echo "$lines" | fzf \
    --ansi \
    --reverse \
    --border=rounded \
    --prompt="session> " \
    --header="$header" \
    --preview="$preview_cmd" \
    --preview-window="right:55%:wrap:follow" \
    --expect="1,2,3,n,K,r,R,?" \
  ) || { echo "quit"; return 0; }

  key=$(echo "$selection" | head -1)
  local chosen_line
  chosen_line=$(echo "$selection" | tail -1)
  local chosen_name
  chosen_name=$(echo "$chosen_line" | awk '{print $1}')

  case "$key" in
    1)     echo "action:refresh" ;;
    2)     echo "tab:worktrees" ;;
    3)     echo "tab:panes" ;;
    n)     echo "action:new" ;;
    K)     [[ -z "$chosen_name" ]] && echo "action:refresh" || echo "action:kill:$chosen_name" ;;
    r)     [[ -z "$chosen_name" ]] && echo "action:refresh" || echo "action:rename:$chosen_name" ;;
    R)     echo "action:refresh" ;;
    "?")   echo "action:help" ;;
    *)
      [[ -z "$chosen_name" ]] && echo "quit" || echo "action:switch:$chosen_name"
      ;;
  esac
}

# ──────────────────────────────────────────────────────────────────────────
# Worktrees tab (placeholder)
# ──────────────────────────────────────────────────────────────────────────

render_worktrees_tab() {
  local data lines header
  data=$(lazy_llm_gather_worktrees)

  if [[ -z "$data" ]]; then
    lines="(No worktrees in this repo, or not inside a git repo.)"
    header="[Worktrees] n: new │ R: refresh │ 1: sessions │ 3: panes │ q/esc: close"
  else
    lines=""
    while IFS=$'\t' read -r path branch dirty ahead behind session pr; do
      local short_path="${path/#$HOME/\~}"
      [[ ${#short_path} -gt 38 ]] && short_path="...${short_path: -35}"

      local dirty_mark="${dirty:- }"
      local ab="↑${ahead} ↓${behind}"
      local sess_mark=" "
      [[ -n "$session" ]] && sess_mark="●"
      local pr_mark="   "
      case "$pr" in
        OPEN)   pr_mark="PR●" ;;
        MERGED) pr_mark="PR✓" ;;
        CLOSED) pr_mark="PRx" ;;
      esac

      lines+=$(printf '%-38s  %-24s %s  %-10s %s  %s' \
        "$short_path" "$branch" "$dirty_mark" "$ab" "$sess_mark" "$pr_mark")
      lines+=$'\n'
    done <<< "$data"
    lines="${lines%$'\n'}"
    header="[Worktrees] enter: open/attach │ n: new │ g: lazygit │ K: cleanup │ R: refresh │ ?: help │ 1: sessions │ 3: panes │ q/esc: close"
  fi

  # Preview: git status -sb + recent log for the selected worktree path.
  local preview_cmd
  preview_cmd='set -- {1}; '
  preview_cmd+='wt="$1"; wt="${wt/#\~/$HOME}"; '
  preview_cmd+='if git -C "$wt" rev-parse --git-dir >/dev/null 2>&1; then '
  preview_cmd+='echo "=== git status ==="; git -C "$wt" -c color.status=always status -sb 2>&1 | head -20; '
  preview_cmd+='echo; echo "=== git log -10 ==="; git -C "$wt" -c color.ui=always log --oneline -10 2>&1; '
  preview_cmd+='else echo "(preview unavailable: $wt)"; fi'

  local selection key
  selection=$(echo "$lines" | fzf \
    --ansi \
    --reverse \
    --border=rounded \
    --prompt="worktree> " \
    --header="$header" \
    --preview="$preview_cmd" \
    --preview-window="right:55%:wrap:follow" \
    --expect="1,2,3,n,g,K,R,?" \
  ) || { echo "quit"; return 0; }

  key=$(echo "$selection" | head -1)
  local chosen_line chosen_path
  chosen_line=$(echo "$selection" | tail -1)
  chosen_path=$(echo "$chosen_line" | awk '{print $1}')
  chosen_path="${chosen_path/#\~/$HOME}"
  [[ -d "$chosen_path" ]] || chosen_path=""

  case "$key" in
    1)   echo "tab:sessions" ;;
    2)   echo "action:refresh" ;;
    3)   echo "tab:panes" ;;
    n)   echo "action:worktree-new" ;;
    g)   [[ -z "$chosen_path" ]] && echo "action:refresh" || echo "action:worktree-lazygit:$chosen_path" ;;
    K)   [[ -z "$chosen_path" ]] && echo "action:refresh" || echo "action:worktree-cleanup:$chosen_path" ;;
    R)   echo "action:refresh" ;;
    "?") echo "action:help" ;;
    *)
      [[ -z "$chosen_path" ]] && echo "quit" || echo "action:worktree-open:$chosen_path"
      ;;
  esac
}

# ──────────────────────────────────────────────────────────────────────────
# Panes tab — list AI panes in the current session/window with live preview
# ──────────────────────────────────────────────────────────────────────────

render_panes_tab() {
  # Resolve current tmux context. If we're not in a tmux session at all,
  # the popup was launched from outside — graceful empty-state.
  lazy_llm_resolve_pane 2>/dev/null || {
    local body="(Not inside a tmux session. The Panes tab needs a current pane to read AI panes from.)"
    local header="[Panes] q/esc: close │ 1: sessions │ 2: worktrees"
    local selection key
    selection=$(echo "$body" | fzf --ansi --reverse --border=rounded \
      --prompt="panes> " --header="$header" --expect="1,2" \
    ) || { echo "quit"; return 0; }
    key=$(echo "$selection" | head -1)
    case "$key" in
      1) echo "tab:sessions" ;;
      2) echo "tab:worktrees" ;;
      *) echo "quit" ;;
    esac
    return 0
  }
  lazy_llm_resolve_session_window 2>/dev/null
  lazy_llm_read_multi_state

  local lines="" header empty=false
  if [[ -z "$AI_PANES" ]]; then
    # Window isn't a lazy-llm workspace. Discoverable empty-state.
    lines="(No AI panes in this window. Run lazy-llm or press 'a' to bootstrap one.)"
    header="[Panes] Not a lazy-llm workspace. a: add │ 1: sessions │ 2: worktrees │ q/esc: close"
    empty=true
  else
    # Build per-pane rows with status glyph + pane ID column for preview indexing
    local -a pane_arr tool_arr
    read -ra pane_arr <<< "$AI_PANES"
    read -ra tool_arr <<< "$AI_TOOLS"
    local current_idx="${AI_PANE_IDX:-0}"
    local total=${#pane_arr[@]}

    local i
    for i in "${!pane_arr[@]}"; do
      local pid="${pane_arr[$i]}"
      local tool="${tool_arr[$i]:-?}"
      local glyph status
      status=$(lazy_llm_detect_pane_status "$pid" "$tool")
      glyph=$(glyph_for "$status")
      local marker=""
      [[ "$i" -eq "$current_idx" ]] && marker="(active)"
      local idx_one=$((i + 1))
      lines+=$(printf '%-3s %-12s %s %-10s %s\n' \
        "$idx_one" "$tool" "$glyph" "$marker" "$pid")
      lines+=$'\n'
    done
    lines="${lines%$'\n'}"

    header="[Panes] enter: switch │ a: add │ K: kill │ ]/[: cycle │ R: refresh │ ?: help │ 1: sessions │ 2: worktrees │ q/esc: close"
  fi

  # Preview: take the pane id from column 5 (idx 5 in fzf field syntax),
  # render its content with ANSI. Empty-state row has no pane id → skip.
  local preview_cmd
  if [[ "$empty" == "true" ]]; then
    preview_cmd='echo "(no panes to preview)"'
  else
    preview_cmd='set -- {5}; pid="$1"; '
    preview_cmd+='if [ -n "$pid" ]; then '
    preview_cmd+='tmux capture-pane -p -e -S -200 -t "$pid" 2>/dev/null || echo "(could not capture pane $pid)"; '
    preview_cmd+='else echo "(no pane id in row)"; fi'
  fi

  local selection key
  selection=$(echo "$lines" | fzf \
    --ansi \
    --reverse \
    --border=rounded \
    --prompt="pane> " \
    --header="$header" \
    --preview="$preview_cmd" \
    --preview-window="right:55%:wrap:follow" \
    --expect="1,2,3,a,K,],[,R,?" \
  ) || { echo "quit"; return 0; }

  key=$(echo "$selection" | head -1)
  local chosen_line
  chosen_line=$(echo "$selection" | tail -1)
  # First column is the 1-indexed pane number (or empty for the placeholder)
  local chosen_idx
  chosen_idx=$(echo "$chosen_line" | awk '{print $1}')
  # Sanitize: only digits, otherwise treat as empty (e.g. for the placeholder row)
  [[ "$chosen_idx" =~ ^[0-9]+$ ]] || chosen_idx=""

  case "$key" in
    1)     echo "tab:sessions" ;;
    2)     echo "tab:worktrees" ;;
    3)     echo "action:refresh" ;;
    a)     echo "action:pane-add" ;;
    K)     [[ -z "$chosen_idx" ]] && echo "action:refresh" || echo "action:pane-remove:$chosen_idx" ;;
    "]")   echo "action:pane-next" ;;
    "[")   echo "action:pane-prev" ;;
    R)     echo "action:refresh" ;;
    "?")   echo "action:help" ;;
    *)
      [[ -z "$chosen_idx" ]] && echo "quit" || echo "action:pane-cycle:$chosen_idx"
      ;;
  esac
}

# ──────────────────────────────────────────────────────────────────────────
# Action dispatch
# ──────────────────────────────────────────────────────────────────────────

dispatch_action() {
  local action="$1"
  case "$action" in
    action:new)
      tmux display-popup -E "$HOME/.local/bin/lazy-llm"
      ;;
    action:switch:*)
      local name="${action#action:switch:}"
      tmux switch-client -t "$name" 2>/dev/null \
        || tmux attach-session -t "$name" 2>/dev/null \
        || echo "Could not switch to $name" >&2
      # switching exits the popup naturally
      ;;
    action:kill:*)
      local name="${action#action:kill:}"
      # Use llm-sessions --kill for the validated kill path (checks @lazy_llm marker)
      local confirm
      confirm=$(printf 'no\nyes' | fzf \
        --reverse --border=rounded --header="Kill session '$name'?" \
        --prompt="confirm> " || echo no)
      if [[ "$confirm" == "yes" ]]; then
        "$HOME/.local/bin/llm-sessions" --kill "$name" >&2 || true
      fi
      ;;
    action:rename:*)
      local name="${action#action:rename:}"
      local new_name
      new_name=$(echo "" | fzf --print-query \
        --reverse --border=rounded \
        --header="Rename session '$name' to:" \
        --prompt="new name> " \
        --query="$name" \
        --no-info \
        --bind 'enter:accept-non-empty' \
        --expect=enter | head -1 || true)
      if [[ -n "$new_name" ]] && [[ "$new_name" != "$name" ]]; then
        tmux rename-session -t "$name" "$new_name" 2>/dev/null \
          || echo "Could not rename to $new_name" >&2
      fi
      ;;
    action:help)
      show_help_overlay
      ;;
    action:refresh)
      : # outer loop re-renders the current tab
      ;;
    action:pane-cycle:*)
      local idx="${action#action:pane-cycle:}"
      [[ -n "$idx" ]] && "$HOME/.local/bin/llm-cycle" "$idx" >&2 || true
      ;;
    action:pane-add)
      local tool
      tool=$(printf 'claude\ngemini\ncodex\ngrok\naider' | fzf \
        --reverse --border=rounded --prompt="tool> " \
        --header="Pick an AI tool to add (esc to cancel):" \
        --no-info)
      [[ -n "$tool" ]] && "$HOME/.local/bin/llm-add" -t "$tool" >&2 || true
      ;;
    action:pane-remove:*)
      local idx="${action#action:pane-remove:}"
      [[ -z "$idx" ]] && return 0
      local confirm
      confirm=$(printf 'no\nyes' | fzf \
        --reverse --border=rounded --header="Remove pane $idx?" \
        --prompt="confirm> " || echo no)
      [[ "$confirm" == "yes" ]] && "$HOME/.local/bin/llm-remove" -f "$idx" >&2 || true
      ;;
    action:pane-next)
      "$HOME/.local/bin/llm-cycle" next >&2 || true
      ;;
    action:pane-prev)
      "$HOME/.local/bin/llm-cycle" prev >&2 || true
      ;;
    action:worktree-open:*)
      local path="${action#action:worktree-open:}"
      local branch
      branch=$(git -C "$path" branch --show-current 2>/dev/null)
      if [[ -n "$branch" ]]; then
        "$HOME/.local/bin/lazy-llm" -W "$branch" >&2 || true
      fi
      ;;
    action:worktree-new)
      local new_branch
      new_branch=$(echo "" | fzf --print-query --reverse --border=rounded \
        --header="New worktree — branch name (will be created from HEAD if it doesn't exist):" \
        --prompt="branch> " --no-info \
        --bind 'enter:accept-non-empty' | head -1)
      if [[ -n "$new_branch" ]]; then
        "$HOME/.local/bin/lazy-llm" -W "$new_branch" >&2 || true
      fi
      ;;
    action:worktree-lazygit:*)
      local path="${action#action:worktree-lazygit:}"
      if command -v lazygit >/dev/null 2>&1; then
        tmux display-popup -E -w 95% -h 90% "lazygit -p '$path'"
      else
        tmux display-message "lazygit not installed"
      fi
      ;;
    action:worktree-cleanup:*)
      local path="${action#action:worktree-cleanup:}"
      _dashboard_worktree_cleanup_flow "$path"
      ;;
  esac
}

# Cleanup flow with pre-flight warnings and dual confirms.
# Lives in the dashboard (not the lib) because the prompts are fzf-bound.
_dashboard_worktree_cleanup_flow() {
  local path="$1"
  local repo branch session ahead_count default warnings_text=""
  repo=$(git -C "$path" rev-parse --show-toplevel 2>/dev/null) || return 1
  branch=$(git -C "$path" branch --show-current 2>/dev/null)
  if [[ -z "$branch" ]]; then
    tmux display-message "Detached worktree — refusing to cleanup"
    return 1
  fi

  default=$(lazy_llm_default_branch "$repo")

  if [[ -n "$(git -C "$path" status --porcelain 2>/dev/null)" ]]; then
    warnings_text+="⚠  Worktree has uncommitted changes"$'\n'
  fi
  ahead_count=$(git -C "$path" rev-list --count "origin/$default..HEAD" 2>/dev/null || echo 0)
  if [[ "$ahead_count" -gt 0 ]]; then
    warnings_text+="⚠  Branch is $ahead_count commits ahead of origin/$default — they will be lost if branch is deleted"$'\n'
  fi
  if ! git -C "$path" rev-parse --verify "@{u}" >/dev/null 2>&1; then
    warnings_text+="⚠  Branch has no upstream — local-only commits will be lost"$'\n'
  fi
  session=$(lazy_llm_find_session_for_path "$path")
  if [[ -n "$session" ]]; then
    warnings_text+="⚠  Will kill attached lazy-llm session '$session'"$'\n'
  fi
  if command -v gh >/dev/null 2>&1; then
    local pr_state
    pr_state=$(gh pr view "$branch" --json state -q .state 2>/dev/null) || pr_state=""
    [[ "$pr_state" == "OPEN" ]] && warnings_text+="⚠  Open PR — branch deletion may close it remotely"$'\n'
  fi

  local confirm body
  body=$(printf 'Cleanup worktree: %s\nBranch: %s\n%s' "$path" "$branch" "${warnings_text:-(no warnings — clean removal)}")
  confirm=$(printf 'no\nyes' | fzf --reverse --border=rounded \
    --header="$body" --prompt="remove worktree? " || echo no)
  [[ "$confirm" != "yes" ]] && return 0

  local default_choice="yes"
  [[ -n "$warnings_text" ]] && default_choice="no"
  local del_branch
  del_branch=$(printf 'no\nyes' | fzf --reverse --border=rounded \
    --header="Also delete branch '$branch'? (data loss risk if warnings shown)" \
    --prompt="delete branch ($default_choice)? " || echo "$default_choice")

  local force="no"
  [[ -n "$warnings_text" ]] && force="yes"

  if lazy_llm_cleanup_worktree "$path" "$del_branch" "$force"; then
    tmux display-message "Cleaned up '$path'"
  fi
}

show_help_overlay() {
  local help_text
  help_text="lazy-llm dashboard — keybindings

  Tabs
    1            switch to Sessions tab
    2            switch to Worktrees tab
    3            switch to Panes tab

  Sessions tab
    Enter        switch to selected session
    n            new lazy-llm session
    K            kill selected session (with confirmation)
    r            rename selected session
    R            refresh list
    ?            this help

  Worktrees tab
    Enter        open/attach lazy-llm session in worktree (via lazy-llm -W)
    n            new worktree + session (prompts for branch)
    g            launch lazygit pointed at the worktree
    K            atomic cleanup (session + worktree + optional branch)
    R            refresh list

  Panes tab
    Enter        cycle to selected AI pane
    a            add a new AI pane (tool picker)
    K            remove selected pane (with confirmation)
    ]            cycle to next AI pane
    [            cycle to previous AI pane
    R            refresh list

  Global
    q / Esc      close the dashboard

Press any key to dismiss."
  tmux display-popup -E -w 60% -h 50% bash -c "
    cat <<'EOF'
$help_text
EOF
    read -rsn1
  "
}

# ──────────────────────────────────────────────────────────────────────────
# CLI handling
# ──────────────────────────────────────────────────────────────────────────

usage() {
  cat <<'EOF'
Usage: llm-dashboard [--tab sessions|worktrees|panes] [--help]

Tabbed popup dashboard for lazy-llm. Launches Sessions tab by default.

Inside the dashboard:
  1, 2, 3    switch tabs (Sessions, Worktrees, Panes)
  Enter      primary action (switch session / open worktree / cycle pane)
  n          new session (Sessions) / new worktree+session (Worktrees)
  a          add new AI pane (Panes)
  g          launch lazygit (Worktrees)
  K          kill / remove / cleanup (with confirmation)
  r          rename (Sessions)
  ], [       cycle next / prev AI pane (Panes)
  R          refresh
  ?          help
  q, Esc     close
EOF
}

# Parse args
current_tab=sessions
while [[ $# -gt 0 ]]; do
  case "$1" in
    --tab)
      shift
      case "$1" in
        sessions|worktrees|panes) current_tab="$1" ;;
        *) echo "Unknown tab: $1" >&2; exit 2 ;;
      esac
      shift
      ;;
    --help|-h) usage; exit 0 ;;
    *) echo "Unknown arg: $1" >&2; usage >&2; exit 2 ;;
  esac
done

# ──────────────────────────────────────────────────────────────────────────
# Main outer loop — tab dispatch
# ──────────────────────────────────────────────────────────────────────────

if ! command -v fzf &>/dev/null; then
  echo "Error: fzf is required" >&2
  exit 1
fi

while true; do
  case "$current_tab" in
    sessions)  result=$(render_sessions_tab) ;;
    worktrees) result=$(render_worktrees_tab) ;;
    panes)     result=$(render_panes_tab) ;;
    *)         echo "Unknown tab: $current_tab" >&2; exit 1 ;;
  esac

  case "$result" in
    tab:*)
      current_tab="${result#tab:}"
      ;;
    action:switch:*|action:kill:*|action:rename:*|action:new|action:help|action:refresh|action:pane-cycle:*|action:pane-add|action:pane-remove:*|action:pane-next|action:pane-prev|action:worktree-open:*|action:worktree-new|action:worktree-lazygit:*|action:worktree-cleanup:*)
      dispatch_action "$result"
      # Switch action exits the popup; for others we re-enter the current tab
      [[ "$result" == action:switch:* ]] && break
      ;;
    quit|"")
      break
      ;;
    *)
      echo "Unexpected result: $result" >&2
      break
      ;;
  esac
done
